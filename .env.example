# ─────────────────────────────────────────────────────────────────────────────
# Veritas Platform — Environment Variables Reference
# Copy this file to .env for local development (never commit .env)
# ─────────────────────────────────────────────────────────────────────────────

# ── API Server (artifacts/api-server) ─────────────────────────────────────

# PostgreSQL connection string (required)
# Local:      postgres://postgres:password@localhost:5432/veritas
# Supabase:   postgresql://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres
#             (find this in: Supabase dashboard → Project Settings → Database → Connection string → URI)
DATABASE_URL=postgres://postgres:password@localhost:5432/veritas

# JWT signing secret — use a long random string in production (required)
SESSION_SECRET=change-me-to-a-long-random-secret

# Port the API server listens on (required — set automatically by workflow/Render)
PORT=5000

# Comma-separated list of allowed frontend origins for CORS (optional)
# Leave unset for permissive mode during local development
# Example: https://veritas-platform.netlify.app,https://www.veritasinfra.com
ALLOWED_ORIGINS=http://localhost:5173

# ── Email / SMTP (optional) ───────────────────────────────────────────────
# Leave all SMTP_ vars unset to disable transactional email entirely

# SMTP server hostname
SMTP_HOST=smtp.gmail.com

# SMTP port (587 = STARTTLS, 465 = SSL)
SMTP_PORT=587

# SMTP auth credentials
SMTP_USER=you@example.com
SMTP_PASS=your-app-password

# Recipient for admin-level system notifications
ADMIN_EMAIL=admin@example.com

# Public URL of the platform — used in email links
PLATFORM_URL=https://veritas-platform.netlify.app

# ── Frontend (artifacts/veritas) ──────────────────────────────────────────

# Base URL of the deployed API server (required for cross-origin deploys)
# Set this in Netlify: Site settings → Build & deploy → Environment variables
# Leave empty for local dev (Vite proxy handles /api → localhost:5000)
VITE_API_URL=https://veritas-api.onrender.com
